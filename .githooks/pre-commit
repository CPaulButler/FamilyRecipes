#!/bin/sh
set -e

HOOK_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
REPO_ROOT=$(CDPATH= cd -- "$HOOK_DIR/.." && pwd)

if command -v python3 >/dev/null 2>&1; then
    PYTHON_BIN=python3
elif command -v python >/dev/null 2>&1; then
    PYTHON_BIN=python
else
    echo "Python is required to update CSS cache-busting params." >&2
    exit 1
fi

cd "$REPO_ROOT"
"$PYTHON_BIN" tools/update-css-cache-bust.py

git add -u -- "*.html"
